# ─── Shopify Storefront API ───────────────────────────────────────────────────
# Your Shopify store domain (without https://)
# Example: your-store.myshopify.com
VITE_SHOPIFY_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token (public, safe to expose in the browser)
# Shopify Admin → Settings → Apps and sales channels → Develop apps
# → Create an app → Configure Storefront API → Generate token
# Required scopes: unauthenticated_read_product_listings, unauthenticated_write_checkouts
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-token
